# SPDX-License-Identifier: MIT
# ShellWatch demo SSH server config.
# Every demo user runs a single ForceCommand payload. No interactive shells.

Port 22

# Host keys live outside /etc/ssh so a persistence volume can be mounted
# without shadowing sshd_config or the rest of /etc/ssh. The entrypoint
# generates any missing keys on startup.
HostKey /var/lib/demo/host-keys/ssh_host_ed25519_key
HostKey /var/lib/demo/host-keys/ssh_host_rsa_key
HostKey /var/lib/demo/host-keys/ssh_host_ecdsa_key

PermitRootLogin no
PasswordAuthentication no
KbdInteractiveAuthentication no
PubkeyAuthentication yes

# Keys are resolved by a helper script rather than a static file. The
# script (payloads/auth-keys.sh) branches on $SHELLWATCH_KEYS_URL:
#   set   -> HTTP GET against ShellWatch with (user, key type, fingerprint)
#   unset -> read /var/lib/demo/keys/<user> (legacy bind-mount mode)
# %u = user, %t = offered key type, %f = SHA256 fingerprint of offered key.
# `none` disables the default ~/.ssh/authorized_keys lookups — we don't
# need them (demo users have no home), and skipping them removes one
# pointless preauth step per connection.
AuthorizedKeysFile none
AuthorizedKeysCommand /usr/local/lib/demo/auth-keys.sh %u %t %f
AuthorizedKeysCommandUser nobody

# Explicitly allow ShellWatch's headline credential (WebAuthn-anchored sk key).
# `+` appends to OpenSSH's defaults so we don't accidentally narrow other algorithms.
# The cert variant (webauthn-sk-ecdsa-sha2-nistp256-cert-v01@openssh.com) is not yet
# a recognized keytype in OpenSSH 9.7p1's PubkeyAcceptedAlgorithms registry; add it
# back to this line once it lands upstream (or when ShellWatch acts as CA).
PubkeyAcceptedAlgorithms +webauthn-sk-ecdsa-sha2-nistp256@openssh.com

# Uncomment and point at a ShellWatch CA pubkey to make the cert variant useful.
# Until then the cert algorithm is allowed but no certs will validate.
# TrustedUserCAKeys /etc/ssh/shellwatch_ca.pub

# LogLevel is set on the sshd command line in entrypoint.sh (driven by
# $SSHD_LOG_LEVEL, default INFO). Override there, not here, so we have one
# source of truth.

UseDNS no

MaxStartups 10:30:60
LoginGraceTime 10
ClientAliveInterval 15
ClientAliveCountMax 2

PermitTTY yes
AllowTcpForwarding no
AllowAgentForwarding no
X11Forwarding no
PermitTunnel no
PermitUserRC no
PermitUserEnvironment no
GatewayPorts no

Subsystem sftp internal-sftp
# (sftp is loaded but every user's ForceCommand replaces it; no file access)

Match User sw-snake
    ForceCommand /usr/local/lib/demo/snake.sh

Match User sw-matrix
    ForceCommand /usr/local/lib/demo/matrix.sh

Match User sw-sudoku
    ForceCommand /usr/local/lib/demo/sudoku.sh

Match User sw-2048
    ForceCommand /usr/local/lib/demo/2048.sh